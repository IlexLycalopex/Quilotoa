# Database
DATABASE_URL=postgresql://msas:msas@localhost:5432/msas_dev

# JWT
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:5173

# Storage (PDF files)
# For local dev, PDFs are stored on disk. Set to 's3' for production.
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage/proposals
# STORAGE_S3_BUCKET=
# STORAGE_S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Web app (Vite)
VITE_API_URL=http://localhost:3001/api/v1
